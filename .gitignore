## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]ealses/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/

# Visual Studio 2015/2017 cache/options directory
.vs/
# Visual Studio 2017 auto generated files
Generated\ Files/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUNIT
*.VisualState.xml
TestResult.xml

# Build Results of an ATL Project
[Dd]ebugPS/
[Rr]eleasePS/
dlldata.c

# Benchmark Results
BenchmarkDotNet.Artifacts/

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# ASP.NET Scaffolding
ScaffoldingReadMe.txt

# StyleCop
StyleCopReport.xml

# FxCop
FxCopReport.xml

# Service Fabric Backup files
**/*.chk.xml

# RIM Blackberry
**/*.dblock
**/*.iaf_netcore
**/*.iaf_wcf
**/*.iaf_wp
**/*.iaf_xap
**/*.lock
**/*.meta
**/*.pdb
**/*.swp
**/*.tlog
**/*.user
**/*.userprefs
**/*.vcxproj.user
**/*.xap
**/*.xproj.user

# Windows Image Acquisition
Thumbs.db
ehthumbs.db
Desktop.ini

# Restore Ignore Extensions
*.dll
*.exe
*.pdb
*.obj
*.cache

# Office Temp Files
~$*

# ClickOnce
*.publish/
